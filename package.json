{
  "name": "realtime-overlays",
  "version": "1.0.0",
  "description": "Sistema de Gráficos Superpuestos Autónomo para OBS Studio / vMix",
  "main": "src/server/server.js",
  "scripts": {
    "start": "NODE_ENV=production node src/server/server.js",
    "dev": "concurrently -n server,client \"node --watch-path=src/server src/server/server.js\" \"vite\"",
    "build": "vite build"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "gsap": "^3.15.0",
    "helmet": "^8.1.0",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "vite": "^8.0.13"
  }
}
